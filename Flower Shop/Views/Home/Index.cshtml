@model IReadOnlyCollection<FlowerViewModel>
@{
    ViewData["Title"] = "Catalog";

    var totalStock = Model.Sum(f => f.AvailableQuantity);
    var startingPrice = Model.Count > 0 ? Model.Min(f => f.Price) : 0;
    var heroImage = Model.FirstOrDefault(f => !string.IsNullOrWhiteSpace(f.ImageUrl))?.ImageUrl
        ?? "https://images.unsplash.com/photo-1526047932273-341f2a7631f9?auto=format&fit=crop&w=1600&q=80";
}

<section class="shop-hero" style="--hero-image: url('@heroImage')">
    <div class="container">
        <div class="shop-hero-content">
            <span class="eyebrow">Same-day floral ordering</span>
            <h1>Fresh arrangements, ready for delivery.</h1>
            <p>Choose a bouquet, add quantities, and place a customer order in a few clean steps.</p>
            <div class="hero-actions">
                <a class="btn btn-primary btn-lg" asp-controller="Orders" asp-action="Create">Start an order</a>
                <a class="btn btn-light btn-lg" href="#catalog">View catalog</a>
            </div>
        </div>
    </div>
</section>

<section class="container section-stack" id="catalog">
    <div class="metric-row">
        <div class="metric-card">
            <span class="metric-label">Arrangements</span>
            <strong>@Model.Count</strong>
        </div>
        <div class="metric-card">
            <span class="metric-label">In stock</span>
            <strong>@totalStock</strong>
        </div>
        <div class="metric-card">
            <span class="metric-label">Starting at</span>
            <strong>@startingPrice.ToString("C")</strong>
        </div>
    </div>

    <div class="section-heading">
        <div>
            <span class="eyebrow">Catalog</span>
            <h2>Available flowers</h2>
        </div>
        <a class="btn btn-outline-primary" asp-controller="Orders" asp-action="Create">Create order</a>
    </div>

    <div class="catalog-grid">
        @foreach (var flower in Model)
        {
            <article class="product-card">
                @if (!string.IsNullOrWhiteSpace(flower.ImageUrl))
                {
                    <img class="product-image" src="@flower.ImageUrl" alt="@flower.Name" />
                }
                <div class="product-body">
                    <div class="product-title-row">
                        <h3>@flower.Name</h3>
                        <span>@flower.Price.ToString("C")</span>
                    </div>
                    <p>@flower.Description</p>
                    <div class="product-footer">
                        <span class="stock-pill @(flower.AvailableQuantity <= 5 ? "stock-low" : null)">
                            @flower.AvailableQuantity available
                        </span>
                        <a class="btn btn-outline-primary btn-sm" asp-controller="Orders" asp-action="Create">Order</a>
                    </div>
                </div>
            </article>
        }
    </div>
</section>
