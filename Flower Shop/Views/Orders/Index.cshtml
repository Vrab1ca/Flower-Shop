@model IReadOnlyCollection<OrderListViewModel>
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Orders</h1>
        <p class="text-muted mb-0">Processing queue for customer flower orders.</p>
    </div>
</div>

<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th scope="col">Order</th>
                <th scope="col">Customer</th>
                <th scope="col">Date</th>
                <th scope="col">Status</th>
                <th scope="col" class="text-end">Total</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.OrderId</td>
                <td>
                    <div class="fw-semibold">@order.CustomerName</div>
                    <div class="text-muted small">@order.CustomerEmail</div>
                </td>
                <td>@order.OrderDate.ToLocalTime().ToString("g")</td>
                <td><span class="status-pill">@order.Status</span></td>
                <td class="text-end">@order.TotalPrice.ToString("C")</td>
                <td class="text-end">
                    <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@order.OrderId">Open</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
