@model OrderCreateViewModel
@{
    ViewData["Title"] = "Create Order";
}

<section class="container page-heading">
    <div>
        <span class="eyebrow">Customer order</span>
        <h1>Create a delivery order</h1>
        <p>Enter the customer details, select flowers, and review the live total before submitting.</p>
    </div>
</section>

<form asp-action="Create" method="post" class="container order-layout" data-order-form data-currency="USD">
    <div class="order-main">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="progress-strip" aria-label="Order progress">
            <span class="progress-step is-active">Customer</span>
            <span class="progress-step is-active">Flowers</span>
            <span class="progress-step">Confirm</span>
        </div>

        <section class="form-panel">
            <div class="panel-heading">
                <div>
                    <span class="step-badge">1</span>
                    <h2>Customer details</h2>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="CustomerFirstName" class="form-label"></label>
                    <input asp-for="CustomerFirstName" class="form-control form-control-lg" autocomplete="given-name" />
                    <span asp-validation-for="CustomerFirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CustomerLastName" class="form-label"></label>
                    <input asp-for="CustomerLastName" class="form-control form-control-lg" autocomplete="family-name" />
                    <span asp-validation-for="CustomerLastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CustomerEmail" class="form-label"></label>
                    <input asp-for="CustomerEmail" class="form-control form-control-lg" autocomplete="email" />
                    <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="form-panel">
            <div class="panel-heading">
                <div>
                    <span class="step-badge">2</span>
                    <h2>Select flowers</h2>
                </div>
                <span asp-validation-for="Items" class="text-danger"></span>
            </div>

            <div class="order-grid">
                @for (var i = 0; i < Model.Items.Count; i++)
                {
                    var itemImage = string.IsNullOrWhiteSpace(Model.Items[i].ImageUrl)
                        ? "https://images.unsplash.com/photo-1526047932273-341f2a7631f9?auto=format&fit=crop&w=900&q=80"
                        : Model.Items[i].ImageUrl;

                    <article class="order-item" data-order-item data-price="@Model.Items[i].Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                        <input type="hidden" asp-for="Items[i].FlowerId" />
                        <input type="hidden" asp-for="Items[i].FlowerName" />
                        <input type="hidden" asp-for="Items[i].Description" />
                        <input type="hidden" asp-for="Items[i].Price" />
                        <input type="hidden" asp-for="Items[i].AvailableQuantity" />
                        <input type="hidden" asp-for="Items[i].ImageUrl" />
                        <img class="order-item-image" src="@itemImage" alt="@Model.Items[i].FlowerName" />
                        <div class="order-item-body">
                            <div>
                                <div class="product-title-row">
                                    <h3>@Model.Items[i].FlowerName</h3>
                                    <span>@Model.Items[i].Price.ToString("C")</span>
                                </div>
                                <p>@Model.Items[i].Description</p>
                                <span class="stock-pill @(Model.Items[i].AvailableQuantity <= 5 ? "stock-low" : null)">
                                    @Model.Items[i].AvailableQuantity available
                                </span>
                            </div>
                            <div class="quantity-row">
                                <label asp-for="Items[i].Quantity" class="form-label"></label>
                                <div class="quantity-control">
                                    <button type="button" class="btn btn-outline-secondary" data-quantity-step="-1" aria-label="Decrease quantity">-</button>
                                    <input asp-for="Items[i].Quantity" class="form-control quantity-input" min="0" max="@Model.Items[i].AvailableQuantity" />
                                    <button type="button" class="btn btn-outline-secondary" data-quantity-step="1" aria-label="Increase quantity">+</button>
                                </div>
                                <div class="order-line-total" data-line-total>@Model.Items[i].Subtotal.ToString("C")</div>
                                <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>

    <aside class="order-summary" aria-label="Order summary">
        <span class="eyebrow">Summary</span>
        <h2>Review total</h2>
        <div class="summary-line">
            <span>Selected stems</span>
            <strong data-order-count>0</strong>
        </div>
        <div class="summary-line summary-total">
            <span>Total</span>
            <strong data-order-total>@Model.TotalPrice.ToString("C")</strong>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-100">Place order</button>
        <a class="btn btn-outline-secondary w-100" asp-controller="Home" asp-action="Index">Back to catalog</a>
    </aside>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
