@model OrderCreateViewModel
@{
    ViewData["Title"] = "Create Order";
}

<h1 class="h2 mb-4">Create Order</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <section class="form-panel mb-4">
        <h2 class="h5 mb-3">Customer</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="CustomerFirstName" class="form-label"></label>
                <input asp-for="CustomerFirstName" class="form-control" />
                <span asp-validation-for="CustomerFirstName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerLastName" class="form-label"></label>
                <input asp-for="CustomerLastName" class="form-control" />
                <span asp-validation-for="CustomerLastName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerEmail" class="form-label"></label>
                <input asp-for="CustomerEmail" class="form-control" />
                <span asp-validation-for="CustomerEmail" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-panel">
        <div class="d-flex justify-content-between gap-3 mb-3">
            <h2 class="h5 mb-0">Flowers</h2>
            <span asp-validation-for="Items" class="text-danger"></span>
        </div>

        <div class="order-grid">
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                <article class="order-item">
                    <input type="hidden" asp-for="Items[i].FlowerId" />
                    <input type="hidden" asp-for="Items[i].FlowerName" />
                    <input type="hidden" asp-for="Items[i].Description" />
                    <input type="hidden" asp-for="Items[i].Price" />
                    <input type="hidden" asp-for="Items[i].AvailableQuantity" />
                    <input type="hidden" asp-for="Items[i].ImageUrl" />
                    @if (!string.IsNullOrWhiteSpace(Model.Items[i].ImageUrl))
                    {
                        <img class="order-item-image" src="@Model.Items[i].ImageUrl" alt="@Model.Items[i].FlowerName" />
                    }
                    <div class="order-item-body">
                        <div>
                            <h3 class="h6 mb-1">@Model.Items[i].FlowerName</h3>
                            <p class="text-muted small mb-2">@Model.Items[i].Description</p>
                            <div class="small">
                                <span class="fw-semibold">@Model.Items[i].Price.ToString("C")</span>
                                <span class="text-muted"> · @Model.Items[i].AvailableQuantity available</span>
                            </div>
                        </div>
                        <div>
                            <label asp-for="Items[i].Quantity" class="form-label small"></label>
                            <input asp-for="Items[i].Quantity" class="form-control quantity-input" min="0" max="@Model.Items[i].AvailableQuantity" />
                            <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
                        </div>
                    </div>
                </article>
            }
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
            <div class="fs-5">Estimated total: <strong>@Model.TotalPrice.ToString("C")</strong></div>
            <button type="submit" class="btn btn-primary">Place order</button>
        </div>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
