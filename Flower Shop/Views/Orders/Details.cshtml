@model OrderDetailsViewModel
@{
    ViewData["Title"] = $"Order #{Model.OrderId}";
}

<section class="container page-heading">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <span class="eyebrow">Order details</span>
            <h1>Order #@Model.OrderId</h1>
            <p>@Model.CustomerName · @Model.CustomerEmail</p>
        </div>
        <span class="status-pill">@Model.Status</span>
    </div>
</section>

<section class="container order-layout">
    <div class="order-main">
        <div class="form-panel">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">Placed</div>
                    <div class="fw-semibold">@Model.OrderDate.ToLocalTime().ToString("g")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Items</div>
                    <div class="fw-semibold">@Model.Items.Sum(i => i.Quantity)</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Total</div>
                    <div class="fw-semibold">@Model.TotalPrice.ToString("C")</div>
                </div>
            </div>
        </div>

        <div class="table-panel table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th scope="col">Flower</th>
                        <th scope="col">Price</th>
                        <th scope="col">Quantity</th>
                        <th scope="col" class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@item.FlowerName</td>
                        <td>@item.Price.ToString("C")</td>
                        <td>@item.Quantity</td>
                        <td class="text-end">@item.Subtotal.ToString("C")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <aside class="order-summary">
        <span class="eyebrow">Fulfillment</span>
        <h2>Update status</h2>
        @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Florist))
        {
            <form asp-action="UpdateStatus" asp-route-id="@Model.OrderId" method="post" class="d-grid gap-3">
                <select name="status" class="form-select form-select-lg">
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        <option value="@status" selected="@(status == Model.Status)">@status</option>
                    }
                </select>
                <button type="submit" class="btn btn-primary btn-lg">Save status</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Back to orders</a>
            </form>
        }
        else
        {
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Back to catalog</a>
        }
    </aside>
</section>
