@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isStaff = User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Florist);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flower Shop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark" aria-hidden="true"></span>
                    <span>Flower Shop</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-lg-auto mb-3 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active" : null)"
                               asp-area="" asp-controller="Home" asp-action="Index">Catalog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Orders" && currentAction == "Create" ? "active" : null)"
                               asp-area="" asp-controller="Orders" asp-action="Create">Order</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Flowers" ? "active" : null)"
                               asp-area="" asp-controller="Flowers" asp-action="Index">Inventory</a>
                        </li>
                        @if (isStaff)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Orders" && currentAction != "Create" ? "active" : null)"
                                   asp-area="" asp-controller="Orders" asp-action="Index">Orders</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <main class="site-main" role="main">
        <div class="container">
            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success app-alert" role="alert">@successMessage</div>
            }
            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="alert alert-danger app-alert" role="alert">@errorMessage</div>
            }
        </div>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; 2026 Flower Shop Online Order System</span>
            <span class="text-muted">MVC · EF Core · Identity</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
