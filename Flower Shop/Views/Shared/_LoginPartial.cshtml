@if (User.Identity?.IsAuthenticated == true)
{
    <form class="d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
        <span class="navbar-text small">@User.Identity.Name</span>
        <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
    </form>
}
else
{
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-area="Identity" asp-page="/Account/Login">Login</a>
        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </div>
}
