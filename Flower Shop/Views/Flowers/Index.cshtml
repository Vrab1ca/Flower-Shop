@model IReadOnlyCollection<FlowerViewModel>
@{
    ViewData["Title"] = "Inventory";

    var totalStock = Model.Sum(f => f.AvailableQuantity);
    var lowStock = Model.Count(f => f.AvailableQuantity <= 5);
    var inventoryValue = Model.Sum(f => f.AvailableQuantity * f.Price);
}

<section class="container page-heading">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3">
        <div>
            <span class="eyebrow">Florist workspace</span>
            <h1>Inventory</h1>
            <p>Manage flower availability, pricing, and catalog presentation from one table.</p>
        </div>
        @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Florist))
        {
            <a class="btn btn-primary btn-lg" asp-action="Create">Add flower</a>
        }
    </div>
</section>

<section class="container section-stack">
    <div class="metric-row">
        <div class="metric-card">
            <span class="metric-label">Catalog items</span>
            <strong>@Model.Count</strong>
        </div>
        <div class="metric-card">
            <span class="metric-label">Units in stock</span>
            <strong>@totalStock</strong>
        </div>
        <div class="metric-card">
            <span class="metric-label">Low stock</span>
            <strong>@lowStock</strong>
        </div>
    </div>

    <div class="table-panel table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th scope="col">Flower</th>
                    <th scope="col">Price</th>
                    <th scope="col">Stock</th>
                    <th scope="col">Value</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var flower in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrWhiteSpace(flower.ImageUrl))
                            {
                                <img class="inventory-thumb" src="@flower.ImageUrl" alt="@flower.Name" />
                            }
                            <div>
                                <div class="fw-semibold">@flower.Name</div>
                                <div class="text-muted small">@flower.Description</div>
                            </div>
                        </div>
                    </td>
                    <td>@flower.Price.ToString("C")</td>
                    <td>
                        <span class="stock-pill @(flower.AvailableQuantity <= 5 ? "stock-low" : null)">
                            @flower.AvailableQuantity
                        </span>
                    </td>
                    <td>@((flower.AvailableQuantity * flower.Price).ToString("C"))</td>
                    <td class="text-end">
                        @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Florist))
                        {
                            <div class="btn-group btn-group-sm" role="group" aria-label="Inventory actions">
                                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@flower.FlowerId">Edit</a>
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@flower.FlowerId">Delete</a>
                            </div>
                        }
                    </td>
                </tr>
            }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="fw-semibold">Inventory value</td>
                    <td class="fw-semibold">@inventoryValue.ToString("C")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</section>
