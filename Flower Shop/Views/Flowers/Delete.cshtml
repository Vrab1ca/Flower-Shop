@model FlowerViewModel
@{
    ViewData["Title"] = "Delete Flower";
}

<h1 class="h2 mb-3">Delete Flower</h1>
<div class="form-panel">
    <p class="mb-1">Delete <strong>@Model.Name</strong> from inventory?</p>
    <p class="text-muted">This cannot be completed if existing orders still reference the flower.</p>
    <form asp-action="Delete" asp-route-id="@Model.FlowerId" method="post" class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
