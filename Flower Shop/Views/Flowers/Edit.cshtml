@model FlowerViewModel
@{
    ViewData["Title"] = "Edit Flower";
}

<section class="container page-heading">
    <div>
        <span class="eyebrow">Inventory</span>
        <h1>Edit flower</h1>
        <p>Update catalog details, price, stock quantity, or the product image.</p>
    </div>
</section>

<section class="container">
    <form asp-action="Edit" asp-route-id="@Model.FlowerId" method="post" class="form-panel">
        <partial name="_FlowerForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Save changes</button>
            <a class="btn btn-outline-secondary btn-lg" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
