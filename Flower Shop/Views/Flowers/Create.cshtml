@model FlowerViewModel
@{
    ViewData["Title"] = "Add Flower";
}

<h1 class="h2 mb-4">Add Flower</h1>
<form asp-action="Create" method="post" class="form-panel">
    <partial name="_FlowerForm" model="Model" />
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
