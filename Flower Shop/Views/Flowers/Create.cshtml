@model FlowerViewModel
@{
    ViewData["Title"] = "Add Flower";
}

<section class="container page-heading">
    <div>
        <span class="eyebrow">Inventory</span>
        <h1>Add flower</h1>
        <p>Create a new catalog item with price, stock quantity, and image.</p>
    </div>
</section>

<section class="container">
    <form asp-action="Create" method="post" class="form-panel">
        <partial name="_FlowerForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Save flower</button>
            <a class="btn btn-outline-secondary btn-lg" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
